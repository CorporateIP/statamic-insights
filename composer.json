{
    "name": "corporateip/statamic-insights",
    "description": "First-party analytics for Statamic with a full Control Panel dashboard.",
    "license": "proprietary",
    "authors": [
        {
            "name": "Corporate IP",
            "homepage": "https://www.corporateip.nl"
        }
    ],
    "autoload": {
        "psr-4": {
            "CorporateIp\\Insights\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CorporateIp\\Insights\\Tests\\": "tests"
        }
    },
    "require": {
        "php": "^8.2",
        "jaybizzle/crawler-detect": "^1.3",
        "maxmind-db/reader": "^1.11",
        "statamic/cms": "^6.19"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^10.0 || ^11.0",
        "phpunit/phpunit": "^11.0 || ^12.0"
    },
    "extra": {
        "statamic": {
            "name": "Insights",
            "description": "First-party analytics with a full Control Panel dashboard.",
            "developer": "Corporate IP"
        },
        "laravel": {
            "providers": [
                "CorporateIp\\Insights\\ServiceProvider"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "pixelfear/composer-dist-plugin": true
        }
    },
    "minimum-stability": "stable"
}
